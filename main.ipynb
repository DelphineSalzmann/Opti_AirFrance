    "def update_visualizations(quantity_count, group_data):\n",
    "    \"\"\"\n",
    "    Update boxplot, bar chart, and pie chart visualizations based on group statistics.\n",
    "\n",
    "    Args:\n",
    "        quantity_count (dict): Dictionary containing the count of groups with each quantity.\n",
    "        group_data (dict): Dictionary containing the satisfaction data for each group.\n",
    "    \"\"\"\n",
    "    # Extracting data from dictionaries\n",
    "    group_labels = [f\"{quantity}\" for quantity, _ in quantity_count.items()]  # Extracting only the first value\n",
    "\n",
    "    boxplot_data = [group_data[quantity] for quantity in quantity_count.keys()]\n",
    "\n",
    "    group_sizes = list(quantity_count.values())\n",
    "\n",
    "    # Creating a figure and axes for the boxplot, bar chart, and pie chart\n",
    "    fig, (ax1, ax2, ax3, ax4) = plt.subplots(1, 4, figsize=(20, 6))\n",
    "\n",
    "    # Creating the boxplot\n",
    "    boxplot = ax1.boxplot(boxplot_data, labels=group_labels)\n",
    "\n",
    "    # Adding labels to the axes\n",
    "    ax1.set_ylabel('Satisfaction Score')\n",
    "    ax1.set_xlabel('Group size')\n",
    "    ax1.set_title('Satisfaction Scores in Different Groups')\n",
    "    ax1.grid(True)\n",
    "\n",
    "    # Creating the bar chart\n",
    "    x = np.arange(len(group_labels))  # the label locations\n",
    "    width = 0.5  # the width of the bars\n",
    "\n",
    "    rects1 = ax2.barh(x, group_sizes, width, label='Group Sizes', align='center')  # Centralize as barras\n",
    "\n",
    "    # Adding labels to the axes\n",
    "    ax2.set_yticks(x)\n",
    "    ax2.set_yticklabels(group_labels)  # Display only the first value\n",
    "    ax2.set_ylabel('Size of the groups')  # Adiciona a legenda no eixo y\n",
    "    ax2.set_title('Distribution of Group Sizes')\n",
    "    ax2.set_xlabel('Number of groups')  # Adiciona a legenda no eixo x\n",
    "\n",
    "    # Creating the pie chart\n",
    "    pie_wedges, _, autotexts = ax3.pie(group_sizes, labels=group_labels, autopct='%1.1f%%', startangle=90)\n",
    "    ax3.set_title('Distribution of Group Sizes')\n",
    "\n",
    "    # Formatando os textos dos valores\n",
    "    for autotext in autotexts:\n",
    "        autotext.set_color('white')  # Definindo a cor do texto para branco\n",
    "        autotext.set_fontsize(10)  # Definindo o tamanho da fonte para 10\n",
    "\n",
    "    # Adicionando a legenda extra\n",
    "    legend_labels = [f\"{label}: {size:.2f}%\" for label, size in zip(group_labels, group_sizes)]\n",
    "    ax4.axis('off')  # Desliga os eixos do subplot\n",
    "    ax4.legend(pie_wedges, legend_labels, title='Group Percentage', loc='center left')\n",
    "\n",
    "    # Displaying the plots\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Example usage:\n",
    "update_visualizations(quantity_count, group_data)"
